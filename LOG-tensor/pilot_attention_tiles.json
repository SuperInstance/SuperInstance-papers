  "WHY_TRACE": [
    {
      "n": "Add",
      "traces": "Why is this transaction added to the ledger?",
      "follows": "from_account",
      "py": "lambda x: x['from_account']",
      "induces": "T = T + A",
      "category": "WHY_TRACE"
    },
    {
      "n": "Sub",
      "traces": "Why is this transaction subtracted from the ledger?",
      "follows": "to_account",
      "py": "lambda x: x['to_account']",
      "induces": "T = T - B",
      "category": "WHY_TRACE"
    },
    {
      "n": "Bal",
      "traces": "Why is the account balance calculated?",
      "follows": "transaction_amount",
      "py": "lambda x: x['amount']",
      "induces": "B = B + x['amount']",
      "category": "WHY_TRACE"
    },
    {
      "n": "Int",
      "traces": "Why is interest charged?",
      "follows": "due_date",
      "py": "lambda x: x['due_date']",
      "induces": "I = D * x['int_rate'] * (x['due_date'] - x['transaction_date']) / 365",
      "category": "WHY_TRACE"
    },
    {
      "n": "Due",
      "traces": "Why is the payment due?",
      "follows": "due_notification",
      "py": "lambda x: x['notification_date']",
      "induces": "D = D if x['notification_date'] <= x['due_date'] else False",
      "category": "WHY_TRACE"
    },
    {
      "n": "Rec",
      "traces": "Why is the receipt generated?",
      "follows": "transaction_id",
      "py": "lambda x: x['transaction_id']}",
      "induces": "R = R + (x['amount'], x['transaction_id'])",
      "category": "WHY_TRACE"
    }
  ],
