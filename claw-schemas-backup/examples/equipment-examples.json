  "examples": [
    {
      "name": "ternary-memory",
      "slot": "MEMORY",
      "version": "1.0.0",
      "description": "Ternary weight memory using -1, 0, +1 values for efficient storage and recall of experience patterns. Provides 3x compression compared to binary encoding while maintaining pattern recognition accuracy.",
      "cost": {
        "memory_bytes": 10485760,
        "cpu_percent": 2.5,
        "latency_ms": 0.5,
        "cost_per_use": 0.0,
        "energy_joules": 0.01
      },
      "benefit": {
        "accuracy_boost": 0.15,
        "speed_multiplier": 3.0,
        "confidence_boost": 0.1,
        "capability_gain": ["ternary_storage", "pattern_compression", "efficient_recall"],
        "reliability_improvement": 0.08
      },
      "trigger_thresholds": {
        "equip_when": {
          "task_type_matches": ["pattern_recognition", "sequence_learning", "experience_replay"],
          "frequency_above": 10,
          "resource_available": {
            "memory_bytes": 52428800,
            "cpu_percent": 20.0
          }
        },
        "unequip_when": {
          "idle_duration_exceeds": 300,
          "resource_pressure": {
            "memory_below": 52428800
          },
          "cost_benefit_ratio": 2.0
        },
        "call_teacher": {
          "min_confidence": 0.5,
          "max_confidence": 0.8,
          "teacher_equipment": "consensus-teacher"
        }
      },
      "capabilities": [
        {
          "name": "ternary-storage",
          "description": "Store patterns using -1, 0, +1 weights for efficient representation",
          "metrics": {
            "throughput": 10000,
            "accuracy": 0.95,
            "latency_p50": 0.3,
            "latency_p99": 1.0
          }
        },
        {
          "name": "pattern-compression",
          "description": "Compress patterns by 3x compared to binary encoding",
          "metrics": {
            "throughput": 5000,
            "accuracy": 0.98,
            "latency_p50": 0.5,
            "latency_p99": 2.0
          }
        },
        {
          "name": "efficient-recall",
          "description": "Fast pattern recall using ternary indexing",
          "metrics": {
            "throughput": 15000,
            "accuracy": 0.92,
            "latency_p50": 0.2,
            "latency_p99": 0.8
          }
        }
      ],
      "dependencies": [],
      "conflicts": ["binary-memory", "quantized-memory", "floating-point-memory"],
      "muscle_memory": {
        "triggers": [
          {
            "condition": {
              "type": "pattern_match",
              "pattern": "ternary|three-valued|trivalent|tripartite",
              "metric": "task_description"
            },
            "action": "equip",
            "priority": 80,
            "cooldown_seconds": 30
          },
          {
            "condition": {
              "type": "threshold_cross",
              "metric": "accuracy",
              "threshold": 0.85,
              "direction": "below"
            },
            "action": "recommend",
            "priority": 60,
            "cooldown_seconds": 60
          },
          {
            "condition": {
              "type": "frequency_exceeded",
              "metric": "pattern_recognition_tasks",
              "threshold": 5,
              "window_seconds": 60
            },
            "action": "equip",
            "priority": 70,
            "cooldown_seconds": 120
          }
        ],
        "use_count": 0,
        "success_rate": 0.0
      },
      "implementation": {
        "type": "native",
        "entry_point": "claw::equipment::memory::TernaryMemory",
        "language": "rust",
        "requirements": ["memory-10mb"]
      },
      "metadata": {
        "author": "SuperInstance Team",
        "license": "MIT",
        "tags": ["memory", "ternary", "compression", "efficient", "patterns"],
        "documentation_url": "https://docs.superinstance.ai/equipment/ternary-memory",
        "source_url": "https://github.com/SuperInstance/polln/tree/main/claw/equipment/memory",
        "created_at": "2026-03-15T00:00:00Z",
        "updated_at": "2026-03-15T00:00:00Z"
      }
    },
    {
      "name": "consensus-deadband",
      "slot": "CONSENSUS",
      "version": "2.1.0",
      "description": "Deadband consensus that only deliberates when confidence falls within the uncertainty band (0.5-0.8). Outside this range, either proceed independently (high confidence >0.8) or defer to teacher (low confidence <0.5). Dramatically reduces unnecessary deliberation overhead.",
      "cost": {
        "memory_bytes": 52428800,
        "cpu_percent": 15.0,
        "latency_ms": 5.0,
        "cost_per_use": 0.0,
        "energy_joules": 0.5
      },
      "benefit": {
        "accuracy_boost": 0.25,
        "speed_multiplier": 1.5,
        "confidence_boost": 0.3,
        "capability_gain": ["distributed_consensus", "deadband_filtering", "conflict_resolution", "uncertainty_estimation"],
        "reliability_improvement": 0.2
      },
      "trigger_thresholds": {
        "equip_when": {
          "confidence_below": 0.8,
          "task_type_matches": ["multi_claw_coordination", "distributed_decision", "consensus_required"],
          "resource_available": {
            "memory_bytes": 104857600,
            "cpu_percent": 30.0
          }
        },
        "unequip_when": {
          "confidence_above": 0.95,
          "idle_duration_exceeds": 600
        },
        "call_teacher": {
          "min_confidence": 0.0,
          "max_confidence": 0.5,
          "teacher_equipment": "human-teacher"
        }
      },
      "capabilities": [
        {
          "name": "deadband-filtering",
          "description": "Filter decisions based on confidence deadband to reduce unnecessary deliberation",
          "metrics": {
            "throughput": 100,
            "accuracy": 0.92,
            "latency_p50": 3.0,
            "latency_p99": 10.0
          }
        },
        {
          "name": "distributed-consensus",
          "description": "Reach consensus across multiple claws using deadband-optimized protocol",
          "metrics": {
            "throughput": 50,
            "accuracy": 0.95,
            "latency_p50": 5.0,
            "latency_p99": 20.0
          }
        },
        {
          "name": "conflict-resolution",
          "description": "Resolve conflicts between claws through structured deliberation",
          "metrics": {
            "throughput": 25,
            "accuracy": 0.88,
            "latency_p50": 10.0,
            "latency_p99": 30.0
          }
        }
      ],
      "dependencies": ["communication-message-passing"],
      "conflicts": ["consensus-voting", "consensus-ensemble", "consensus-hierarchical"],
      "muscle_memory": {
        "triggers": [
          {
            "condition": {
              "type": "threshold_cross",
              "metric": "confidence",
              "threshold": 0.8,
              "direction": "below"
            },
            "action": "equip",
            "priority": 90,
            "cooldown_seconds": 10
          },
          {
            "condition": {
              "type": "pattern_match",
              "pattern": "consensus|agree|deliberate|vote",
              "metric": "task_description"
            },
            "action": "equip",
            "priority": 75,
            "cooldown_seconds": 30
          }
        ],
        "use_count": 0,
        "success_rate": 0.0
      },
      "implementation": {
        "type": "native",
        "entry_point": "claw::equipment::consensus::DeadbandConsensus",
        "language": "rust",
        "requirements": ["network-connection", "multi-claw"]
      },
      "metadata": {
        "author": "SuperInstance Team",
        "license": "MIT",
        "tags": ["consensus", "deadband", "distributed", "coordination", "multi-agent"],
        "created_at": "2026-03-10T00:00:00Z",
        "updated_at": "2026-03-15T00:00:00Z"
      }
    },
