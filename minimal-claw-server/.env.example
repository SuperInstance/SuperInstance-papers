# =============================================================================
# Minimal CLAW Server - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# Node environment (development, staging, production)
NODE_ENV=production

# Server port
PORT=8080

# Application version (optional, for deployment tracking)
APP_VERSION=0.1.0-mvp

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------

# Database host (use 'postgres' for Docker container)
DB_HOST=postgres

# Database port
DB_PORT=5432

# Database name
DB_NAME=clawdb

# Database user
DB_USER=clawuser

# Database password (CHANGE THIS!)
DB_PASSWORD=clawpass

# Database connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10

# Database SSL mode (disable, require, verify-ca, verify-full)
DB_SSL_MODE=disable

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------

# Redis host (use 'redis' for Docker container)
REDIS_HOST=redis

# Redis port
REDIS_PORT=6379

# Redis password (CHANGE THIS!)
REDIS_PASSWORD=redispass

# Redis database number
REDIS_DB=0

# Redis key prefix
REDIS_KEY_PREFIX=claw:

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------

# JWT secret for authentication (CHANGE THIS!)
JWT_SECRET=your-super-secret-jwt-key-change-this

# JWT expiration time (e.g., 1d, 7d, 30d)
JWT_EXPIRES_IN=7d

# JWT refresh token expiration
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------

# API rate limiting (requests per minute)
API_RATE_LIMIT=60

# API rate limiting window (in seconds)
API_RATE_WINDOW=60

# Maximum request body size (e.g., 10mb, 100mb)
MAX_BODY_SIZE=10mb

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# -----------------------------------------------------------------------------
# WebSocket Configuration
# -----------------------------------------------------------------------------

# WebSocket port (uses same port as HTTP if not specified)
WS_PORT=

# WebSocket heartbeat interval (milliseconds)
WS_HEARTBEAT=30000

# Maximum WebSocket connections
WS_MAX_CONNECTIONS=1000

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------

# Default agent model
DEFAULT_MODEL=deepseek-chat

# Maximum agents per instance
MAX_AGENTS=1000

# Agent timeout (milliseconds)
AGENT_TIMEOUT=30000

# Agent memory limit (MB)
AGENT_MEMORY_LIMIT=512

# -----------------------------------------------------------------------------
# Monitoring & Logging
# -----------------------------------------------------------------------------

# Enable request logging
ENABLE_REQUEST_LOGGING=true

# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING=true

# Log format (json, text)
LOG_FORMAT=json

# Log directory
LOG_DIR=/app/logs

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Enable Sentry tracing
SENTRY_TRACING=false

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------

# OpenAI API key (if using OpenAI models)
OPENAI_API_KEY=

# Anthropic API key (if using Claude models)
ANTHROPIC_API_KEY=

# DeepSeek API key (if using DeepSeek models)
DEEPSEEK_API_KEY=

# Custom API endpoint (for self-hosted models)
CUSTOM_API_ENDPOINT=

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------

# Enable HTTPS (requires SSL certificates)
ENABLE_HTTPS=false

# SSL certificate path
SSL_CERT_PATH=

# SSL key path
SSL_KEY_PATH=

# Enable API key authentication
ENABLE_API_KEY_AUTH=true

# Enable CORS
ENABLE_CORS=true

# Enable helmet security headers
ENABLE_HELMET=true

# -----------------------------------------------------------------------------
# Email Configuration (optional, for notifications)
# -----------------------------------------------------------------------------

# SMTP host
SMTP_HOST=

# SMTP port
SMTP_PORT=587

# SMTP user
SMTP_USER=

# SMTP password
SMTP_PASSWORD=

# Email from address
EMAIL_FROM=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable database persistence
ENABLE_DB_PERSISTENCE=true

# Enable Redis caching
ENABLE_REDIS_CACHE=true

# Enable WebSocket compression
ENABLE_WS_COMPRESSION=true

# Enable graceful shutdown
ENABLE_GRACEFUL_SHUTDOWN=true

# -----------------------------------------------------------------------------
# Deployment Configuration
# -----------------------------------------------------------------------------

# Deployment environment (development, staging, production)
DEPLOYMENT_ENV=production

# Deployment region (for cloud deployments)
DEPLOYMENT_REGION=

# Enable maintenance mode
MAINTENANCE_MODE=false

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------

# Docker Compose project name
COMPOSE_PROJECT_NAME=minimal-claw-server

# Nginx HTTP port
NGINX_HTTP_PORT=80

# Nginx HTTPS port
NGINX_HTTPS_PORT=443

# Adminer port (database management UI)
ADMINER_PORT=8081

# Redis Commander port (Redis management UI)
REDIS_COMMANDER_PORT=8082

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------

# Enable automatic backups
ENABLE_AUTO_BACKUP=true

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# Backup directory
BACKUP_DIR=/app/backups

# -----------------------------------------------------------------------------
# Development Configuration
# -----------------------------------------------------------------------------

# Enable hot reload (development only)
ENABLE_HOT_RELOAD=false

# Enable debug mode
DEBUG=false

# Enable test mode
TEST=false
