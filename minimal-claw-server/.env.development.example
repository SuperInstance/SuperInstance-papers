# =============================================================================
# Development Environment Configuration
# =============================================================================

NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clawdb_dev
DB_USER=clawuser
DB_PASSWORD=devpass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRES_IN=1d

# API
API_RATE_LIMIT=1000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Features
ENABLE_HOT_RELOAD=true
DEBUG=true
ENABLE_REQUEST_LOGGING=true

# Docker
COMPOSE_PROJECT_NAME=minimal-claw-server-dev
ADMINER_PORT=8081
REDIS_COMMANDER_PORT=8082
