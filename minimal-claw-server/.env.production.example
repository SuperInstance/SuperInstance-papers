# =============================================================================
# Production Environment Configuration
# =============================================================================
# IMPORTANT: Review and update all values before deploying to production
# =============================================================================

NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# Database - CHANGE THESE PASSWORDS!
DB_HOST=postgres
DB_PORT=5432
DB_NAME=clawdb
DB_USER=clawuser
DB_PASSWORD=CHANGE_THIS_PASSWORD_NOW

# Redis - CHANGE THIS PASSWORD!
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# JWT - CHANGE THIS SECRET!
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# API
API_RATE_LIMIT=60
CORS_ORIGINS=https://your-domain.com

# Security
ENABLE_HTTPS=true
ENABLE_API_KEY_AUTH=true
ENABLE_HELMET=true

# Monitoring
SENTRY_DSN=your-sentry-dsn-here
SENTRY_TRACING=true

# Email (configure for production alerts)
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@your-domain.com

# Backups
ENABLE_AUTO_BACKUP=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# Features
ENABLE_DB_PERSISTENCE=true
ENABLE_REDIS_CACHE=true
ENABLE_WS_COMPRESSION=true
MAINTENANCE_MODE=false
